# .gitignore for Godot 4.x Hearth project

# Godot-specific directories
.godot/
dist/
build/
*.exe
*.dll
*.so
*.dylib

# Editor settings
.vscode/
*.swp
*.swo
*~
.DS_Store

# Ignore import cache
.import/

# Python cache
__pycache__/
*.pyc

# Build artifacts
bin/
obj/

# IDE
.idea/
*.iml

# OS
Thumbs.db
.DS_Store

# User-specific settings (optional)
user_data/

# Generated files
*.translation
