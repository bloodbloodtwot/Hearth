[gd_project]

config_version=5

[application]

config/name="Hearth"
config/description="A textile-themed, emotion-driven game with Spindle Run, realm building, and deep narrative."
config/version="0.0.1"
config/icon="res://icon.svg"
run/main_scene="res://src/scenes/main.tscn"

[debug]

gdscript/warnings/unused_variable=1
gdscript/warnings/unused_argument=1

[rendering]

textures/vram_compression/import_etc2_astc=true
global_illumination/sdfgi/enabled=true
global_illumination/sdfgi/cascade_count=2

[physics]

3d/default_gravity=9.8

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[audio]

buses/default_bus_layout="res://src/audio/default_bus_layout.tres"
